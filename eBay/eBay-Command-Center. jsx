  const [qty, setQty] = useState("1");
  const [shipCost, setShipCost] = useState("4.99");
  const [condition, setCondition] = useState("3000");
  const [skuType, setSkuType] = useState("OWN");
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);
  const [photos, setPhotos] = useState([]);
  const [uploading, setUploading] = useState(false);
  const [uploadStatus, setUploadStatus] = useState("");
  const fileRef = useRef();
  const r2Ready = r2cfg.accountId && r2cfg.accessKey && r2cfg.secretKey && r2cfg.bucket && r2cfg.publicUrl;

  const CONDITIONS=[["1000","New"],["1500","New other"],["2000","Mfr refurb"],["2500","Seller refurb"],["3000","Used"],["4000","Very Good"],["5000","Good"],["6000","Acceptable"],["7000","For parts"]];

  const nextSku = () => {
    const prefix = skuType+"-";
    const existing = inv.filter(i=>i.sku.startsWith(prefix)).map(i=>parseInt(i.sku.replace(prefix,""))||0);
    return `${prefix}${String((existing.length?Math.max(...existing):0)+1).padStart(5,"0")}`;
  };

  const handlePhotos = async (files) => {
    if (!r2Ready) { setUploadStatus("⚠️ Configure R2 in Settings first"); return; }
    setUploading(true);
    const urls = [];
    for (const f of Array.from(files)) {
      try {
        setUploadStatus(`Uploading ${f.name}...`);
        const url = await uploadToR2(f, r2cfg);
        urls.push(url);
      } catch(e) { setUploadStatus(`❌ Failed: ${f.name}`); }
    }
    setPhotos(p=>[...p,...urls]);
    setUploadStatus(`✅ ${urls.length} photo${urls.length!==1?"s":""} uploaded`);
    setUploading(false);
  };

  const generate = async () => {
    if (!desc.trim()) return;
    setLoading(true); setResult(null);
    try {
      const sku = nextSku();
      const text = await callClaude(
        `Create an eBay listing for: "${desc}"\nRespond ONLY with JSON:\n{"title":"(max 80 chars)","description":"(3-4 sentences)","suggestedCategory":"(eBay category)","keywords":["k1","k2","k3","k4","k5"]}`,
        "You are an expert eBay seller. Return only valid JSON, no backticks."
