// ── Claude ───────────────────────────────────────────────────────────────────
async function callClaude(prompt, sys="You are an expert eBay seller assistant.") {
  const res = await fetch(API_URL, {
    method:"POST", headers:{"Content-Type":"application/json"},
    body: JSON.stringify({ model:"claude-sonnet-4-20250514", max_tokens:1000, system:sys, messages:[{role:"user",content:prompt}] })
  });
  const d = await res.json();
  return d.content?.[0]?.text || "";
}

// ── R2 Upload ────────────────────────────────────────────────────────────────
async function uploadToR2(file, cfg) {
  // Uses R2's S3-compatible presigned URL approach via fetch
  // cfg: { accountId, accessKey, secretKey, bucket, publicUrl }
  const key = `ebay/${Date.now()}-${file.name.replace(/\s/g,"_")}`;
  const endpoint = `https://${cfg.accountId}.r2.cloudflarestorage.com/${cfg.bucket}/${key}`;
  // Sign with AWS Signature V4 (simplified for R2)
  const date = new Date();
  const dateStr = date.toISOString().replace(/[:\-]|\.\d{3}/g,"").slice(0,15)+"Z";
  const dateShort = dateStr.slice(0,8);
  const region = "auto";
  const service = "s3";
  const credScope = `${dateShort}/${region}/${service}/aws4_request`;
  const signedHeaders = "content-type;host;x-amz-date";
  const host = `${cfg.accountId}.r2.cloudflarestorage.com`;
  const canonicalUri = `/${cfg.bucket}/${key}`;
  const contentType = file.type || "application/octet-stream";

  // Build canonical request
  const canonicalHeaders = `content-type:${contentType}\nhost:${host}\nx-amz-date:${dateStr}\n`;
  const buf = await file.arrayBuffer();
  const hashBuf = await crypto.subtle.digest("SHA-256", buf);
  const payloadHash = Array.from(new Uint8Array(hashBuf)).map(b=>b.toString(16).padStart(2,"0")).join("");
  const canonicalRequest = `PUT\n${canonicalUri}\n\n${canonicalHeaders}\n${signedHeaders}\n${payloadHash}`;

  // String to sign
  const crHash = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(canonicalRequest));
  const crHex = Array.from(new Uint8Array(crHash)).map(b=>b.toString(16).padStart(2,"0")).join("");
  const strToSign = `AWS4-HMAC-SHA256\n${dateStr}\n${credScope}\n${crHex}`;

  // Signing key
  const hmac = async (k, d) => {
    const key = typeof k === "string" ? new TextEncoder().encode(k) : k;
    const ck = await crypto.subtle.importKey("raw", key, {name:"HMAC",hash:"SHA-256"}, false, ["sign"]);
    return new Uint8Array(await crypto.subtle.sign("HMAC", ck, new TextEncoder().encode(d)));
  };
  const kDate = await hmac(`AWS4${cfg.secretKey}`, dateShort);
  const kRegion = await hmac(kDate, region);
  const kService = await hmac(kRegion, service);
  const kSigning = await hmac(kService, "aws4_request");
  const sigBuf = await hmac(kSigning, strToSign);
  const signature = Array.from(sigBuf).map(b=>b.toString(16).padStart(2,"0")).join("");

  const authHeader = `AWS4-HMAC-SHA256 Credential=${cfg.accessKey}/${credScope}, SignedHeaders=${signedHeaders}, Signature=${signature}`;

  const resp = await fetch(endpoint, {
    method:"PUT",
    headers: { "Content-Type":contentType, "x-amz-date":dateStr, "Authorization":authHeader },
    body: buf
  });
  if (!resp.ok) throw new Error(`R2 upload failed: ${resp.status}`);
  return `${cfg.publicUrl}/${key}`;
}

// ── CSV ───────────────────────────────────────────────────────────────────────
const CSV_HEADERS = ["Action","CustomLabel","Title","Description","PicURL","Category","StartPrice","Quantity","ConditionID","ShippingService","ShippingServiceCost","ShipToLocations","SiteID","Currency","ListingType","ListingDuration"];
function listingToRow(l) {
  return [
    "Add", l.sku||"", l.title||"",
    (l.description||"").replace(/\n/g," "),
    (l.photos||[]).join("|"),
    l.category||"0", l.price||"", l.qty||"1",
    l.conditionId||"3000", "USPSFirstClass",
    l.shipCost||"4.99", "US","0","USD","FixedPrice","GTC"
  ];
}
function downloadCSV(listings, filename="ebay_listings") {
  const rows = [CSV_HEADERS, ...listings.map(l => listingToRow(l).map(v=>`"${String(v).replace(/"/g,'""')}"`))]
    .map(r=>r.join(",")).join("\n");
  const a = document.createElement("a");
  a.href = URL.createObjectURL(new Blob([rows],{type:"text/csv"}));
  a.download = `${filename}_${Date.now()}.csv`;
  a.click();
}

