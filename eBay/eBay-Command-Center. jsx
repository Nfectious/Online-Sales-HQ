        {/* Photo Upload */}
        <div style={{marginBottom:12}}>
          <div style={{fontSize:11,color:"#7070a0",marginBottom:6}}>📷 Photos {!r2Ready&&<span style={{color:"#f87171"}}>(configure R2 in Settings)</span>}</div>
          <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:6}}>
