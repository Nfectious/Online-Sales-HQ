                <img src={url} alt="" style={{width:60,height:60,objectFit:"cover",borderRadius:8,border:"1px solid #3d3d6e"}}/>
                <button onClick={()=>setPhotos(p=>p.filter((_,j)=>j!==i))}
                  style={{position:"absolute",top:-4,right:-4,background:"#f87171",border:"none",borderRadius:"50%",width:18,height:18,color:"#fff",fontSize:10,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center"}}>✕</button>
              </div>
            ))}
            <button onClick={()=>fileRef.current?.click()} disabled={uploading||!r2Ready}
              style={{width:60,height:60,background:"#0f0f1a",border:"2px dashed #3d3d6e",borderRadius:8,color:"#a78bfa",fontSize:22,cursor:r2Ready?"pointer":"not-allowed",display:"flex",alignItems:"center",justifyContent:"center"}}>
              {uploading?"⏳":"+"}
            </button>
          </div>
          <input ref={fileRef} type="file" accept="image/*" multiple capture="environment" style={{display:"none"}}
            onChange={e=>handlePhotos(e.target.files)}/>
          {uploadStatus&&<div style={{fontSize:11,color:uploadStatus.startsWith("✅")?"#34d399":uploadStatus.startsWith("❌")?"#f87171":"#fbbf24"}}>{uploadStatus}</div>}
        </div>

        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
          <div>{inp("Price ($)",price,setPrice,"24.99")}</div>
          <div>{inp("Quantity",qty,setQty,"1")}</div>
        </div>
        {inp("Shipping Cost ($)",shipCost,setShipCost,"4.99")}

        <div style={{marginBottom:10}}>
          <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>Condition</div>
          <select value={condition} onChange={e=>setCondition(e.target.value)}
            style={{width:"100%",background:"#1a1a3e",border:"1px solid #2d2d5e",borderRadius:8,color:"#e2e8f0",padding:"10px 12px",fontSize:13}}>
            {CONDITIONS.map(([v,l])=><option key={v} value={v}>{l}</option>)}
          </select>
        </div>

        <div style={{marginBottom:14}}>
          <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>SKU Type</div>
          <div style={{display:"flex",gap:8}}>
            {["OWN","DS"].map(t=>(
              <button key={t} onClick={()=>setSkuType(t)}
                style={{flex:1,padding:"8px",border:"none",borderRadius:8,cursor:"pointer",fontWeight:600,fontSize:12,
                  background:skuType===t?"#a78bfa":"#2d2d5e",color:skuType===t?"#fff":"#a0a0c0"}}>
                {t==="OWN"?"Own Stock":"Dropship"}
              </button>
            ))}
          </div>
        </div>

        <button onClick={generate} disabled={loading||!desc.trim()}
          style={{width:"100%",background:loading?"#4a3a7a":"linear-gradient(135deg,#7c3aed,#a78bfa)",border:"none",borderRadius:10,color:"#fff",padding:"12px",fontSize:14,fontWeight:700,cursor:loading?"wait":"pointer"}}>
          {loading?"⚡ Generating...":"⚡ Generate Listing"}
        </button>
      </div>

      {result&&!result.error&&(
        <div style={{background:"#1a1a3e",borderRadius:12,padding:14,border:"1px solid #34d39950"}}>
          <div style={{fontSize:12,color:"#34d399",fontWeight:600,marginBottom:10}}>✅ Ready — {result.sku}</div>
          <div style={{fontSize:11,color:"#7070a0",marginBottom:2}}>Title</div>
          <div style={{fontSize:13,color:"#e2e8f0",marginBottom:10,fontWeight:600}}>{result.title}</div>
          <div style={{fontSize:11,color:"#7070a0",marginBottom:2}}>Description</div>
          <div style={{fontSize:12,color:"#c4c4e0",marginBottom:10,lineHeight:1.6}}>{result.description}</div>
          <div style={{fontSize:11,color:"#7070a0",marginBottom:2}}>Category</div>
          <div style={{fontSize:12,color:"#a78bfa",marginBottom:10}}>{result.suggestedCategory}</div>
          {result.photos&&result.photos.length>0&&(
            <div style={{marginBottom:10}}>
              <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>Photos ({result.photos.length})</div>
              <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                {result.photos.map((u,i)=><img key={i} src={u} alt="" style={{width:56,height:56,objectFit:"cover",borderRadius:8,border:"1px solid #3d3d6e"}}/>)}
              </div>
            </div>
          )}
          <div style={{fontSize:11,color:"#7070a0",marginBottom:6}}>Keywords</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:14}}>
            {(result.keywords||[]).map((k,i)=><span key={i} style={{background:"#2d2d5e",borderRadius:20,padding:"3px 10px",fontSize:11,color:"#a78bfa"}}>{k}</span>)}
          </div>
          <div style={{display:"flex",gap:8}}>
            <button onClick={handleDownloadSingle}
              style={{flex:1,background:"linear-gradient(135deg,#059669,#34d399)",border:"none",borderRadius:10,color:"#fff",padding:"11px",fontSize:13,fontWeight:700,cursor:"pointer"}}>
              ⬇ CSV
            </button>
            <button onClick={handleAddToQueue}
              style={{flex:1,background:"linear-gradient(135deg,#7c3aed,#a78bfa)",border:"none",borderRadius:10,color:"#fff",padding:"11px",fontSize:13,fontWeight:700,cursor:"pointer"}}>
              + Queue
            </button>
          </div>
        </div>
      )}
      {result?.error&&<div style={{background:"#3b1515",borderRadius:10,padding:12,color:"#fca5a5",fontSize:13}}>{result.error}</div>}
    </div>
  );
}

// ── QUEUE ─────────────────────────────────────────────────────────────────────
function Queue({ queue, updateQueue }) {
  const remove = i => updateQueue(queue.filter((_,j)=>j!==i));
  const clear = () => updateQueue([]);
  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
        <div style={{fontSize:15,fontWeight:600,color:"#c4b5fd"}}>📋 Listing Queue ({queue.length})</div>
        {queue.length>0&&<button onClick={clear} style={{background:"#3b1515",border:"none",borderRadius:8,color:"#f87171",padding:"6px 12px",fontSize:12,cursor:"pointer"}}>Clear All</button>}
      </div>

      {queue.length===0&&(
        <div style={{background:"#1a1a3e",borderRadius:12,padding:24,textAlign:"center",border:"1px solid #2d2d5e"}}>
          <div style={{fontSize:32,marginBottom:8}}>📋</div>
          <div style={{fontSize:13,color:"#6060a0"}}>No listings queued yet.<br/>Generate listings and tap "+ Queue"</div>
        </div>
      )}

      {queue.map((item,i)=>(
        <div key={i} style={{background:"#1a1a3e",borderRadius:12,padding:12,marginBottom:10,border:"1px solid #2d2d5e"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
            <div style={{flex:1}}>
              <div style={{fontSize:11,color:"#a78bfa",fontWeight:600}}>{item.sku}</div>
              <div style={{fontSize:13,color:"#e2e8f0",marginTop:2}}>{item.title}</div>
              <div style={{fontSize:11,color:"#6060a0",marginTop:2}}>${item.price} · Qty {item.qty} · Ship ${item.shipCost}</div>
              {item.photos&&item.photos.length>0&&<div style={{fontSize:10,color:"#34d399",marginTop:2}}>📷 {item.photos.length} photo{item.photos.length!==1?"s":""}</div>}
            </div>
            <button onClick={()=>remove(i)} style={{background:"#3b1515",border:"none",borderRadius:8,color:"#f87171",padding:"6px 10px",fontSize:11,cursor:"pointer",marginLeft:8}}>✕</button>
          </div>
        </div>
      ))}

      {queue.length>0&&(
        <button onClick={()=>downloadCSV(queue,"ebay_bulk")}
          style={{width:"100%",background:"linear-gradient(135deg,#059669,#34d399)",border:"none",borderRadius:12,color:"#fff",padding:"14px",fontSize:15,fontWeight:700,cursor:"pointer",marginTop:4}}>
          ⬇ Download Bulk CSV ({queue.length} listing{queue.length!==1?"s":""})
        </button>
      )}
    </div>
  );
}

// ── PROMOTED ──────────────────────────────────────────────────────────────────
function Promoted() {
  const [category,setCategory]=useState("");const [price,setPrice]=useState("");const [loading,setLoading]=useState(false);const [advice,setAdvice]=useState("");
  const getAdvice=async()=>{if(!category)return;setLoading(true);setAdvice("");const t=await callClaude(`I sell on eBay in "${category}", avg price $${price||"unknown"}. Give:\n1. Recommended ad rate % and why\n2. Best promotion timing\n3. Budget strategy for small seller\n4. Category-specific tips\nBe specific and actionable.`,"You are an eBay advertising expert.");setAdvice(t);setLoading(false);};
  return (
    <div>
      <div style={{fontSize:15,fontWeight:600,marginBottom:14,color:"#c4b5fd"}}>📣 Promoted Listings Advisor</div>
      <div style={{background:"#1a1a3e",borderRadius:12,padding:14,marginBottom:12,border:"1px solid #2d2d5e"}}>
        <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>Category</div>
        <input value={category} onChange={e=>setCategory(e.target.value)} placeholder="e.g. Tools, Collectibles, Electronics"
          style={{width:"100%",background:"#0f0f1a",border:"1px solid #3d3d6e",borderRadius:8,color:"#e2e8f0",padding:"10px 12px",fontSize:13,marginBottom:10,boxSizing:"border-box"}}/>
        <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>Average Item Price</div>
        <input value={price} onChange={e=>setPrice(e.target.value)} placeholder="e.g. 25"
          style={{width:"100%",background:"#0f0f1a",border:"1px solid #3d3d6e",borderRadius:8,color:"#e2e8f0",padding:"10px 12px",fontSize:13,marginBottom:12,boxSizing:"border-box"}}/>
        <button onClick={getAdvice} disabled={loading||!category}
          style={{width:"100%",background:"linear-gradient(135deg,#7c3aed,#a78bfa)",border:"none",borderRadius:10,color:"#fff",padding:"12px",fontSize:14,fontWeight:700,cursor:loading?"wait":"pointer"}}>
          {loading?"Analyzing...":"Get Ad Strategy"}
        </button>
      </div>
      {advice&&<div style={{background:"#1a1a3e",borderRadius:12,padding:14,border:"1px solid #a78bfa40"}}><div style={{fontSize:12,color:"#a78bfa",fontWeight:600,marginBottom:10}}>📣 Strategy</div><div style={{fontSize:12,color:"#c4c4e0",lineHeight:1.8,whiteSpace:"pre-wrap"}}>{advice}</div></div>}
    </div>
  );
}

// ── PPC ────────────────────────────────────────────────────────────────────────
function PPC() {
  const [item,setItem]=useState("");const [loading,setLoading]=useState(false);const [kw,setKw]=useState(null);
  const getKw=async()=>{if(!item)return;setLoading(true);setKw(null);const t=await callClaude(`eBay PPC keywords for: "${item}"\nReturn ONLY JSON:\n{"primary":["k1","k2","k3"],"longtail":["p1","p2","p3","p4"],"negative":["n1","n2","n3"],"bidStrategy":"paragraph","searchTitle":"optimized title"}`,"Return only valid JSON.");try{setKw(JSON.parse(t.replace(/```json|```/g,"").trim()));}catch{setKw({error:"Parse failed."});}setLoading(false);};
  return (
    <div>
      <div style={{fontSize:15,fontWeight:600,marginBottom:14,color:"#c4b5fd"}}>🔍 PPC Keywords</div>
      <div style={{background:"#1a1a3e",borderRadius:12,padding:14,marginBottom:12,border:"1px solid #2d2d5e"}}>
        <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>Item / Listing</div>
        <input value={item} onChange={e=>setItem(e.target.value)} placeholder="e.g. DeWalt 20V cordless drill set"
          style={{width:"100%",background:"#0f0f1a",border:"1px solid #3d3d6e",borderRadius:8,color:"#e2e8f0",padding:"10px 12px",fontSize:13,marginBottom:12,boxSizing:"border-box"}}/>
        <button onClick={getKw} disabled={loading||!item}
          style={{width:"100%",background:"linear-gradient(135deg,#0891b2,#60a5fa)",border:"none",borderRadius:10,color:"#fff",padding:"12px",fontSize:14,fontWeight:700,cursor:loading?"wait":"pointer"}}>
          {loading?"Finding...":"Generate Keywords"}
        </button>
      </div>
      {kw&&!kw.error&&(
        <div style={{display:"grid",gap:10}}>
          {[["🎯 Primary",kw.primary,"#a78bfa"],["🔎 Long-tail",kw.longtail,"#60a5fa"],["🚫 Negative",kw.negative,"#f87171"]].map(([l,keys,c])=>(
            <div key={l} style={{background:"#1a1a3e",borderRadius:12,padding:14,border:"1px solid #2d2d5e"}}>
              <div style={{fontSize:12,color:c,fontWeight:600,marginBottom:8}}>{l}</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:6}}>{(keys||[]).map((k,i)=><span key={i} style={{background:"#0f0f1a",border:`1px solid ${c}40`,borderRadius:20,padding:"4px 10px",fontSize:11,color:c}}>{k}</span>)}</div>
            </div>
          ))}
          {kw.searchTitle&&<div style={{background:"#1a1a3e",borderRadius:12,padding:14,border:"1px solid #34d39940"}}><div style={{fontSize:12,color:"#34d399",fontWeight:600,marginBottom:6}}>✅ Optimized Title</div><div style={{fontSize:13,color:"#e2e8f0"}}>{kw.searchTitle}</div></div>}
          {kw.bidStrategy&&<div style={{background:"#1a1a3e",borderRadius:12,padding:14,border:"1px solid #2d2d5e"}}><div style={{fontSize:12,color:"#fbbf24",fontWeight:600,marginBottom:6}}>💡 Bid Strategy</div><div style={{fontSize:12,color:"#c4c4e0",lineHeight:1.7}}>{kw.bidStrategy}</div></div>}
        </div>
      )}
      {kw?.error&&<div style={{background:"#3b1515",borderRadius:10,padding:12,color:"#fca5a5",fontSize:13}}>{kw.error}</div>}
    </div>
  );
}

// ── SETTINGS ──────────────────────────────────────────────────────────────────
function Settings({ r2cfg, updateR2 }) {
  const [form, setForm] = useState(r2cfg);
  const [saved, setSaved] = useState(false);
  const [testing, setTesting] = useState(false);
  const [testResult, setTestResult] = useState("");
  useEffect(()=>{ setForm(r2cfg); },[r2cfg]);
  const save = async () => { await updateR2(form); setSaved(true); setTimeout(()=>setSaved(false),2000); };
  const test = async () => {
    setTesting(true); setTestResult("");
    try {
      const blob = new Blob(["test"],{type:"text/plain"});
      const f = new File([blob],"r2_test.txt",{type:"text/plain"});
      const url = await uploadToR2(f, form);
      setTestResult(`✅ Connected! Test file: ${url}`);
    } catch(e) { setTestResult(`❌ Failed: ${e.message}`); }
    setTesting(false);
  };
  const Field = ({label,k,placeholder,secret})=>(
    <div style={{marginBottom:12}}>
      <div style={{fontSize:11,color:"#7070a0",marginBottom:4}}>{label}</div>
      <input type={secret?"password":"text"} value={form[k]||""} onChange={e=>setForm(p=>({...p,[k]:e.target.value}))} placeholder={placeholder}
        style={{width:"100%",background:"#0f0f1a",border:"1px solid #3d3d6e",borderRadius:8,color:"#e2e8f0",padding:"10px 12px",fontSize:13,boxSizing:"border-box"}}/>
    </div>
  );
  return (
    <div>
      <div style={{fontSize:15,fontWeight:600,marginBottom:4,color:"#c4b5fd"}}>⚙️ Settings</div>
      <div style={{fontSize:11,color:"#6060a0",marginBottom:14}}>Cloudflare R2 — photo storage</div>
      <div style={{background:"#1a1a3e",borderRadius:12,padding:14,marginBottom:12,border:"1px solid #2d2d5e"}}>
        <div style={{fontSize:12,color:"#a78bfa",fontWeight:600,marginBottom:12}}>☁️ Cloudflare R2 Credentials</div>
        <Field label="Account ID" k="accountId" placeholder="abc123def456..."/>
        <Field label="Access Key ID" k="accessKey" placeholder="R2 Access Key ID"/>
        <Field label="Secret Access Key" k="secretKey" placeholder="R2 Secret Key" secret/>
        <Field label="Bucket Name" k="bucket" placeholder="ebay-photos"/>
        <Field label="Public URL" k="publicUrl" placeholder="https://pub-xxx.r2.dev"/>
        <div style={{display:"flex",gap:8,marginTop:4}}>
          <button onClick={save} style={{flex:1,background:"linear-gradient(135deg,#7c3aed,#a78bfa)",border:"none",borderRadius:10,color:"#fff",padding:"11px",fontSize:13,fontWeight:700,cursor:"pointer"}}>
            {saved?"✅ Saved!":"Save Settings"}
          </button>
          <button onClick={test} disabled={testing||!form.accountId}
            style={{flex:1,background:"#1a1a3e",border:"1px solid #a78bfa",borderRadius:10,color:"#a78bfa",padding:"11px",fontSize:13,fontWeight:600,cursor:"pointer"}}>
            {testing?"Testing...":"Test R2"}
          </button>
        </div>
        {testResult&&<div style={{marginTop:10,fontSize:11,color:testResult.startsWith("✅")?"#34d399":"#f87171",lineHeight:1.5}}>{testResult}</div>}
      </div>
      <div style={{background:"#1a1a3e",borderRadius:12,padding:14,border:"1px solid #2d2d5e"}}>
        <div style={{fontSize:12,color:"#a78bfa",fontWeight:600,marginBottom:8}}>📋 R2 Setup Guide</div>
        <div style={{fontSize:11,color:"#8080a0",lineHeight:1.8}}>
          1. Go to <span style={{color:"#60a5fa"}}>dash.cloudflare.com</span> → R2{"\n"}
          2. Create a bucket (e.g. <span style={{color:"#a78bfa"}}>ebay-photos</span>){"\n"}
          3. Settings → Public access → Enable{"\n"}
          4. Manage R2 API tokens → Create token{"\n"}
          5. Copy Account ID from R2 overview{"\n"}
          6. Paste all values above → Save → Test
        </div>
      </div>
    </div>
  );
}
