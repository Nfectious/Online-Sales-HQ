    </div>
  );

  return (
    <div>
      <div style={{fontSize:15,fontWeight:600,marginBottom:14,color:"#c4b5fd"}}>✏️ AI Listing Generator</div>
      <div style={{background:"#1a1a3e",borderRadius:12,padding:14,marginBottom:12,border:"1px solid #2d2d5e"}}>
